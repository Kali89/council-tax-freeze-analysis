# Raw and intermediate data — see DATA.md for provenance and how to regenerate.
/data/*
!/data/.gitkeep

# Large generated outputs (CSVs/maps are regenerated by `make all`; keep small
# final deliverables out of .gitignore on a case-by-case basis if we want them
# committed later).
/outputs/*
!/outputs/.gitkeep

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store

# Env
.env
